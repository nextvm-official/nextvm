{
  "name": "nextvm",
  "version": "0.0.0",
  "private": true,
  "description": "NextVM — A Next-Generation FiveM Framework",
  "license": "LGPL-3.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build --concurrency=1",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test --concurrency=1",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "changeset": "changeset",
    "demo:build": "pnpm run build && tsx scripts/build-demo-server.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.4.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.0"
  }
}
