{
  "name": "@nextvm/fxserver-runner",
  "version": "0.1.0",
  "description": "Spawn and manage a local FXServer process for NextVM dev workflows. Generates server.cfg, links built modules into resources/, streams logs, handles cleanup.",
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextvm-official/nextvm.git",
    "directory": "packages/fxserver-runner"
  },
  "homepage": "https://github.com/nextvm-official/nextvm/tree/main/packages/fxserver-runner#readme",
  "bugs": "https://github.com/nextvm-official/nextvm/issues",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
