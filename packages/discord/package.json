{
  "name": "@nextvm/discord",
  "version": "0.0.1",
  "description": "NextVM Discord integration — role sync, log channels, whitelist, status bot",
  "license": "LGPL-3.0",
  "engines": { "node": ">=22.0.0 <23.0.0" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
