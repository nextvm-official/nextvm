    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nextvm/core": "workspace:*",
    "discord.js": "^14.16.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
