{
	"name": "@nextvm/voice",
	"version": "0.0.1",
	"description": "NextVM voice service — server-authoritative radio channels, proximity, phone calls, mute",
	"license": "LGPL-3.0",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nextvm-official/nextvm.git",
		"directory": "packages/voice"
	},
	"homepage": "https://github.com/nextvm-official/nextvm/tree/main/packages/voice#readme",
	"bugs": "https://github.com/nextvm-official/nextvm/issues",
	"engines": {
		"node": ">=22.0.0 <23.0.0"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
		"clean": "rm -rf dist"
	},
	"peerDependencies": {
		"@nextvm/natives": "workspace:*"
	},
	"peerDependenciesMeta": {
		"@nextvm/natives": {
			"optional": true
		}
	},
	"devDependencies": {
		"@nextvm/natives": "workspace:*",
		"@types/node": "^22.0.0",
		"tsup": "^8.4.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	}
}
