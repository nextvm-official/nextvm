{
  "name": "create-nextvm",
  "version": "0.1.0",
  "description": "Scaffold a new NextVM server project. Run via `pnpm create nextvm@latest <name>` or `npm create nextvm@latest <name>`.",
  "license": "BUSL-1.1",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextvm-official/nextvm.git",
    "directory": "packages/create-nextvm"
  },
  "homepage": "https://github.com/nextvm-official/nextvm/tree/main/packages/create-nextvm#readme",
  "bugs": "https://github.com/nextvm-official/nextvm/issues",
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "create-nextvm": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@nextvm/fxserver-runner": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
