{
  "name": "@nextvm/nui-react",
  "version": "0.0.1",
  "description": "React hooks for the NextVM NUI bridge — useNuiMessage, useNuiCallback, useNuiRequest, NuiProvider",
  "license": "LGPL-3.0",
  "engines": { "node": ">=22.0.0 <23.0.0" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@nextvm/nui": "workspace:*",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@nextvm/nui": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
