{
	"name": "@nextvm/cli",
	"version": "0.1.0",
	"description": "NextVM CLI — create, dev, build, validate, db:*, migrate:from",
	"license": "BUSL-1.1",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nextvm-official/nextvm.git",
		"directory": "packages/cli"
	},
	"homepage": "https://github.com/nextvm-official/nextvm/tree/main/packages/cli#readme",
	"bugs": "https://github.com/nextvm-official/nextvm/issues",
	"engines": {
		"node": ">=22.0.0 <23.0.0"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"nextvm": "dist/bin.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@nextvm/build": "workspace:*",
		"@nextvm/core": "workspace:*",
		"@nextvm/db": "workspace:*",
		"@nextvm/fxserver-runner": "workspace:*",
		"@nextvm/migration": "workspace:*",
		"@nextvm/registry": "workspace:*",
		"commander": "^12.1.0",
		"picocolors": "^1.1.0"
	},
	"devDependencies": {
		"tsup": "^8.4.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0",
		"@types/node": "^22.0.0"
	}
}
