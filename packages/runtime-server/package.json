{
  "name": "@nextvm/runtime-server",
  "version": "0.0.1",
  "description": "NextVM server runtime — boots the ModuleLoader inside an FXServer resource and bridges FiveM events to lifecycle hooks",
  "license": "LGPL-3.0",
  "engines": { "node": ">=22.0.0 <23.0.0" },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nextvm/core": "workspace:*",
    "@nextvm/natives": "workspace:*"
  },
  "peerDependencies": {
    "@nextvm/compat": "workspace:*",
    "@nextvm/db": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@nextvm/compat": { "optional": true },
    "@nextvm/db": { "optional": true }
  },
  "devDependencies": {
    "@nextvm/compat": "workspace:*",
    "@nextvm/db": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
