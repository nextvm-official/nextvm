{
	"name": "@nextvm/natives",
	"version": "0.0.1",
	"description": "Typed FiveM native wrappers — Player, Vehicle, World, Entity, Network, Routing, Voice",
	"license": "BUSL-1.1",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nextvm-official/nextvm.git",
		"directory": "packages/natives"
	},
	"homepage": "https://github.com/nextvm-official/nextvm/tree/main/packages/natives#readme",
	"bugs": "https://github.com/nextvm-official/nextvm/issues",
	"engines": {
		"node": ">=22.0.0 <23.0.0"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@citizenfx/server": "*",
		"@citizenfx/client": "*"
	},
	"devDependencies": {
		"tsup": "^8.4.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
