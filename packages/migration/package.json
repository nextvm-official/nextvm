{
	"name": "@nextvm/migration",
	"version": "0.0.1",
	"description": "NextVM migration toolkit — convert ESX/QBCore databases to NextVM schema",
	"license": "LGPL-3.0",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nextvm-official/nextvm.git",
		"directory": "packages/migration"
	},
	"homepage": "https://github.com/nextvm-official/nextvm/tree/main/packages/migration#readme",
	"bugs": "https://github.com/nextvm-official/nextvm/issues",
	"engines": {
		"node": ">=22.0.0 <23.0.0"
	},
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --pool=forks --poolOptions.forks.singleFork=true",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@nextvm/core": "workspace:*",
		"@nextvm/db": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"tsup": "^8.4.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	}
}
